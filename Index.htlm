<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="Mon Budget"/>
<meta name="theme-color" content="#0a0a0f"/>
<title>Mon Budget</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#0a0a0f;--bg2:#13131c;--bg3:#1c1c2a;
  --border:rgba(255,255,255,0.08);--border2:rgba(255,255,255,0.14);
  --text:#f0eff8;--text2:rgba(240,239,248,0.5);--text3:rgba(240,239,248,0.3);
  --green:#3ecf8e;--red:#f87171;--orange:#fb923c;--blue:#60a5fa;--accent:#7c6af7;
  --safe-top:env(safe-area-inset-top,0px);--safe-bottom:env(safe-area-inset-bottom,0px);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;font-size:16px;overscroll-behavior:none}
.app{display:flex;flex-direction:column;height:100dvh;max-width:430px;margin:0 auto;position:relative;overflow:hidden}
.header{padding:calc(var(--safe-top) + 16px) 20px 14px;background:var(--bg);border-bottom:0.5px solid var(--border);flex-shrink:0}
.header-top{display:flex;align-items:flex-start;justify-content:space-between}
.header-label{font-size:11px;color:var(--text3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px}
.header-month{font-family:'DM Serif Display',serif;font-size:28px;color:var(--text);line-height:1}
.header-date{font-size:12px;color:var(--text3);margin-top:4px}
.solde-badge{text-align:right}
.solde-label{font-size:11px;color:var(--text3);margin-bottom:3px}
.solde-val{font-family:'DM Serif Display',serif;font-size:22px}
.solde-val.pos{color:var(--green)}.solde-val.neg{color:var(--red)}
.month-scroll{display:flex;gap:8px;padding:10px 20px;overflow-x:auto;flex-shrink:0;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.month-scroll::-webkit-scrollbar{display:none}
.mtab{flex-shrink:0;font-size:13px;font-weight:500;padding:5px 16px;border-radius:20px;border:0.5px solid var(--border2);background:transparent;color:var(--text2);cursor:pointer;transition:all .2s}
.mtab.active{background:var(--accent);border-color:transparent;color:#fff}
.content{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:0 0 calc(var(--safe-bottom) + 80px)}
.content::-webkit-scrollbar{display:none}
.kpi-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:16px 20px}
.kpi{background:var(--bg2);border:0.5px solid var(--border);border-radius:14px;padding:14px 16px}
.kpi-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px}
.kpi-val{font-size:21px;font-weight:500}
.kpi-sub{font-size:11px;color:var(--text3);margin-top:3px}
.section{padding:0 20px;margin-bottom:20px}
.sec-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.sec-title{font-size:13px;font-weight:500;color:var(--text2);text-transform:uppercase;letter-spacing:.07em}
.sec-badge{font-size:11px;padding:2px 10px;border-radius:12px}
.card{background:var(--bg2);border:0.5px solid var(--border);border-radius:16px;overflow:hidden}
.card-row{display:flex;align-items:center;padding:12px 16px;border-bottom:0.5px solid var(--border)}
.card-row:last-child{border-bottom:none}
.row-icon{width:32px;height:32px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:15px;margin-right:12px;flex-shrink:0;background:rgba(255,255,255,0.05)}
.row-body{flex:1;min-width:0}
.row-name{font-size:14px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.row-sub{font-size:12px;color:var(--text3);margin-top:1px}
.row-amt{font-size:15px;font-weight:500;white-space:nowrap;margin-left:8px}
.row-btn{background:none;border:none;color:var(--text3);cursor:pointer;font-size:17px;padding:4px 8px;border-radius:6px;line-height:1;font-family:'DM Sans',sans-serif}
.empty-state{padding:28px 20px;text-align:center;color:var(--text3);font-size:14px;line-height:1.8}
.kpi{cursor:pointer;transition:opacity .15s}.kpi:active{opacity:.7}
.kpi{cursor:pointer;transition:opacity .15s}.kpi:active{opacity:.7}
.recap-item{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-bottom:0.5px solid var(--border);font-size:14px}
.recap-item:last-child{border-bottom:none}
.recap-label{color:var(--text2)}
.recap-val{font-weight:500}
.recap-divider{height:0.5px;background:var(--border2);margin:0 16px}
.bottom-nav{position:absolute;bottom:0;left:0;right:0;display:flex;background:var(--bg);border-top:0.5px solid var(--border);padding:8px 0 calc(var(--safe-bottom) + 8px)}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;background:none;border:none;cursor:pointer;padding:6px;color:var(--text3);font-family:'DM Sans',sans-serif;font-size:10px;transition:color .15s}
.nav-btn.active{color:var(--accent)}
.nav-icon{font-size:22px;line-height:1}
.sheet-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.65);z-index:100;display:flex;flex-direction:column;justify-content:flex-end;opacity:0;pointer-events:none;transition:opacity .25s}
.sheet-overlay.open{opacity:1;pointer-events:all}
.sheet{background:var(--bg2);border-radius:24px 24px 0 0;padding:20px;padding-bottom:calc(var(--safe-bottom) + 24px);transform:translateY(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);max-height:90dvh;overflow-y:auto}
.sheet-overlay.open .sheet{transform:translateY(0)}
.sheet-handle{width:36px;height:4px;background:var(--border2);border-radius:2px;margin:0 auto 20px}
.sheet-title{font-family:'DM Serif Display',serif;font-size:22px;color:var(--text);margin-bottom:18px}
.type-tabs{display:flex;gap:8px;margin-bottom:18px;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.type-tabs::-webkit-scrollbar{display:none}
.type-tab{flex-shrink:0;font-size:13px;font-weight:500;padding:6px 16px;border-radius:20px;border:0.5px solid var(--border2);background:transparent;color:var(--text2);cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif}
.type-tab.active{background:var(--accent);border-color:transparent;color:#fff}
.field{margin-bottom:14px}
.field label{display:block;font-size:12px;color:var(--text3);margin-bottom:6px;text-transform:uppercase;letter-spacing:.07em}
.field input,.field select{width:100%;background:var(--bg3);border:0.5px solid var(--border2);border-radius:12px;padding:12px 14px;color:var(--text);font-size:16px;font-family:'DM Sans',sans-serif;outline:none;appearance:none;-webkit-appearance:none}
.field input:focus,.field select:focus{border-color:var(--accent)}
.field input::placeholder{color:var(--text3)}
.field select option{background:var(--bg3)}
.btn-main{width:100%;border:none;border-radius:14px;padding:15px;color:#fff;font-size:16px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;margin-top:4px;transition:opacity .15s}
.btn-main:active{opacity:.8}
.btn-secondary{width:100%;border:0.5px solid var(--border2);border-radius:14px;padding:13px;color:var(--text2);font-size:15px;font-family:'DM Sans',sans-serif;cursor:pointer;margin-top:8px;background:transparent}
.toast{position:absolute;top:calc(var(--safe-top) + 12px);left:50%;transform:translateX(-50%) translateY(-80px);background:var(--green);color:#fff;font-size:13px;font-weight:500;padding:10px 20px;border-radius:20px;z-index:200;transition:transform .3s cubic-bezier(.4,0,.2,1);white-space:nowrap}
.toast.show{transform:translateX(-50%) translateY(0)}
.view{display:none}.view.active{display:block}
.dec-box{background:rgba(248,113,113,0.08);border:0.5px solid rgba(248,113,113,0.2);border-radius:16px;padding:16px;display:flex;align-items:center;justify-content:space-between}
.no-dec{background:var(--bg2);border:0.5px solid var(--border);border-radius:16px;padding:20px;text-align:center;color:var(--text3);font-size:14px;line-height:1.8}
.settings-group{padding:0 20px;margin-bottom:24px}
.sg-title{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px;padding-left:4px}
.sr{display:flex;align-items:center;padding:13px 16px;border-bottom:0.5px solid var(--border)}
.sr:last-child{border-bottom:none}
.sr-left{flex:1;min-width:0}
.sr-name{font-size:14px;color:var(--text)}
.sr-sub{font-size:12px;color:var(--text3);margin-top:2px}
.sr-right{display:flex;align-items:center;gap:8px;flex-shrink:0}
.sr-val{font-size:14px;font-weight:500;white-space:nowrap}
.btn-edit{background:none;border:0.5px solid var(--border2);border-radius:8px;padding:5px 12px;color:var(--text2);font-size:12px;cursor:pointer;font-family:'DM Sans',sans-serif}
.btn-del{background:none;border:none;color:var(--text3);cursor:pointer;font-size:18px;padding:2px 6px;border-radius:6px;font-family:'DM Sans',sans-serif}
.btn-del:active{color:var(--red)}
.add-row{display:flex;align-items:center;gap:10px;padding:13px 16px;color:var(--accent);font-size:14px;cursor:pointer;border:none;background:none;font-family:'DM Sans',sans-serif;width:100%}
</style>
</head>
<body>
<div class="app">
<div class="toast" id="toast"></div>

<div class="header">
  <div class="header-top">
    <div>
      <div class="header-label">Budget mensuel</div>
      <div class="header-month" id="hMonth">—</div>
      <div class="header-date" id="hDate"></div>
    </div>
    <div class="solde-badge">
      <div class="solde-label">Solde estimé</div>
      <div class="solde-val pos" id="hSolde">—</div>
    </div>
  </div>
</div>

<div class="month-scroll" id="monthScroll"><div id="monthTabs" style="display:flex;gap:8px"></div></div>

<div class="content" id="content">

  <!-- DASHBOARD -->

  <div class="view active" id="viewDash">
    <div class="kpi-row">
      <div class="kpi" onclick="openFor('dep');setTabDirect('revEx')"><div class="kpi-label">Revenus ＋</div><div class="kpi-val" style="color:var(--green)" id="kRev">—</div><div class="kpi-sub" id="kRevSub">—</div></div>
      <div class="kpi" onclick="switchView('Fix',document.getElementById('navFix'))"><div class="kpi-label">Charges fixes</div><div class="kpi-val" style="color:var(--red)" id="kFix">—</div><div class="kpi-sub" id="kFixSub">—</div></div>
      <div class="kpi" onclick="openFor('dep');setTabDirect('dep')"><div class="kpi-label">Variables ＋</div><div class="kpi-val" style="color:var(--orange)" id="kVar">—</div><div class="kpi-sub" id="kVarSub">—</div></div>
      <div class="kpi" onclick="switchView('Settings',document.getElementById('navSettings'))"><div class="kpi-label">Épargne</div><div class="kpi-val" style="color:var(--blue)" id="kEp">—</div><div class="kpi-sub">Mensuelle</div></div>
    </div>
    <div class="section">
      <div class="sec-header"><span class="sec-title">Récapitulatif</span></div>
      <div class="card" id="recapCard"></div>
    </div>
  </div>

  <!-- CHARGES FIXES -->

  <div class="view" id="viewFix">
    <div class="section" style="padding-top:16px">
      <div class="sec-header">
        <span class="sec-title">Charges fixes</span>
        <span class="sec-badge" style="background:rgba(248,113,113,0.12);color:var(--red)" id="fixTotal2">—</span>
      </div>
      <div class="card" id="fixList"></div>
    </div>
  </div>

  <!-- VARIABLES -->

  <div class="view" id="viewVar">
    <div class="section" style="padding-top:16px">
      <div class="sec-header">
        <span class="sec-title">Dépenses variables</span>
        <span class="sec-badge" style="background:rgba(251,146,60,0.12);color:var(--orange)" id="varBadge">0</span>
      </div>
      <div class="card" id="varList"></div>
    </div>
  </div>

  <!-- RÉGLAGES -->

  <div class="view" id="viewSettings">
    <div style="padding:20px 20px 8px"><p style="font-size:13px;color:var(--text3);line-height:1.7">Modifiez vos revenus, épargnes et charges fixes. Les changements s'appliquent à tous les mois.</p></div>

```
<div class="settings-group">
  <div class="sg-title">Revenus fixes mensuels</div>
  <div class="card"><div id="revList"></div><button class="add-row" onclick="openFor('addRev')">＋ Ajouter un revenu</button></div>
</div>

<div class="settings-group">
  <div class="sg-title">Épargne mensuelle</div>
  <div class="card"><div id="epList"></div><button class="add-row" onclick="openFor('addEp')">＋ Ajouter une épargne</button></div>
</div>

<div class="settings-group">
  <div class="sg-title">Charges fixes</div>
  <div class="card"><div id="cfList"></div><button class="add-row" onclick="openFor('addCf')">＋ Ajouter une charge fixe</button></div>
</div>
```

  </div>

</div>

<div class="bottom-nav">
  <button class="nav-btn active" id="navDash" onclick="switchView('Dash',this)"><span class="nav-icon">◈</span><span>Tableau</span></button>
  <button class="nav-btn" id="navFix" onclick="switchView('Fix',this)"><span class="nav-icon">⊟</span><span>Fixes</span></button>
  <button class="nav-btn" onclick="openFor('dep')"><span class="nav-icon" style="font-size:28px;color:var(--accent)">⊕</span><span style="color:var(--accent)">Ajouter</span></button>
  <button class="nav-btn" id="navVar" onclick="switchView('Var',this)"><span class="nav-icon">⊞</span><span>Variables</span></button>
  <button class="nav-btn" id="navSettings" onclick="switchView('Settings',this)"><span class="nav-icon">⚙</span><span>Réglages</span></button>
</div>

<!-- SHEET -->

<div class="sheet-overlay" id="sheetOverlay" onclick="closeBg(event)">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title" id="sheetTitle">Ajouter</div>
    <div class="type-tabs" id="sheetTabs">
      <button class="type-tab active" onclick="setTab('dep',this)">Dépense</button>
      <button class="type-tab" onclick="setTab('revEx',this)">Revenu exceptionnel</button>
      <button class="type-tab" onclick="setTab('dec',this)">Découvert</button>
    </div>

```
<div id="fDep">
  <div class="field"><label>Description</label><input id="fDepDesc" placeholder="Ex: Courses Carrefour" autocomplete="off"/></div>
  <div class="field"><label>Montant (€)</label><input id="fDepAmt" type="number" min="0" step="0.01" placeholder="0,00" inputmode="decimal"/></div>
  <div class="field"><label>Catégorie</label><select id="fDepCat"><option>Courses</option><option>Essence</option><option>Bébé</option><option>Crèche</option><option>Santé</option><option>Loisirs</option><option>Restaurant</option><option>Vêtements</option><option>Autre</option></select></div>
  <button class="btn-main" style="background:var(--accent)" onclick="submitDep()">Ajouter la dépense</button>
</div>

<div id="fRevEx" style="display:none">
  <div class="field"><label>Description</label><input id="fRevExDesc" placeholder="Ex: Prime, remboursement…" autocomplete="off"/></div>
  <div class="field"><label>Montant (€)</label><input id="fRevExAmt" type="number" min="0" step="0.01" placeholder="0,00" inputmode="decimal"/></div>
  <button class="btn-main" style="background:var(--green)" onclick="submitRevEx()">Ajouter le revenu</button>
</div>

<div id="fDec" style="display:none">
  <p style="font-size:13px;color:var(--text3);margin-bottom:16px;line-height:1.6">Suivi séparé du solde réel. N'impacte pas vos calculs de budget.</p>
  <div class="field"><label>Solde compte (€)</label><input id="fDecAmt" type="number" step="0.01" placeholder="Ex: -450" inputmode="decimal"/></div>
  <div class="field"><label>Note (optionnel)</label><input id="fDecNote" placeholder="Ex: après virement du 5" autocomplete="off"/></div>
  <button class="btn-main" style="background:var(--red)" onclick="submitDec()">Enregistrer</button>
</div>

<div id="fAddRev" style="display:none">
  <div class="field"><label>Libellé</label><input id="fAddRevName" placeholder="Ex: Salaire, CAF…" autocomplete="off"/></div>
  <div class="field"><label>Montant mensuel (€)</label><input id="fAddRevAmt" type="number" min="0" step="0.01" placeholder="0,00" inputmode="decimal"/></div>
  <button class="btn-main" style="background:var(--green)" onclick="submitAddRev()">Enregistrer</button>
</div>

<div id="fAddEp" style="display:none">
  <div class="field"><label>Libellé</label><input id="fAddEpName" placeholder="Ex: Assurance vie, livret…" autocomplete="off"/></div>
  <div class="field"><label>Montant mensuel (€)</label><input id="fAddEpAmt" type="number" min="0" step="0.01" placeholder="0,00" inputmode="decimal"/></div>
  <button class="btn-main" style="background:var(--blue)" onclick="submitAddEp()">Enregistrer</button>
</div>

<div id="fAddCf" style="display:none">
  <div class="field"><label>Libellé</label><input id="fAddCfName" placeholder="Ex: Mutuelle, abonnement…" autocomplete="off"/></div>
  <div class="field"><label>Montant mensuel (€)</label><input id="fAddCfAmt" type="number" min="0" step="0.01" placeholder="0,00" inputmode="decimal"/></div>
  <div class="field"><label>Catégorie</label><select id="fAddCfCat"><option>Abonnements</option><option>Santé</option><option>Logement</option><option>Transport</option><option>Autre</option></select></div>
  <button class="btn-main" style="background:var(--red)" onclick="submitAddCf()">Enregistrer</button>
</div>

<div id="fEditRev" style="display:none">
  <div class="field"><label>Libellé</label><input id="fEditRevName" autocomplete="off"/></div>
  <div class="field"><label>Montant mensuel (€)</label><input id="fEditRevAmt" type="number" min="0" step="0.01" inputmode="decimal"/></div>
  <button class="btn-main" style="background:var(--green)" onclick="submitEditRev()">Enregistrer</button>
  <button class="btn-secondary" onclick="closeSheet()">Annuler</button>
</div>

<div id="fEditEp" style="display:none">
  <div class="field"><label>Libellé</label><input id="fEditEpName" autocomplete="off"/></div>
  <div class="field"><label>Montant mensuel (€)</label><input id="fEditEpAmt" type="number" min="0" step="0.01" inputmode="decimal"/></div>
  <button class="btn-main" style="background:var(--blue)" onclick="submitEditEp()">Enregistrer</button>
  <button class="btn-secondary" onclick="closeSheet()">Annuler</button>
</div>

<div id="fEditCf" style="display:none">
  <div class="field"><label>Libellé</label><input id="fEditCfName" autocomplete="off"/></div>
  <div class="field"><label>Montant mensuel (€)</label><input id="fEditCfAmt" type="number" min="0" step="0.01" inputmode="decimal"/></div>
  <button class="btn-main" style="background:var(--red)" onclick="submitEditCf()">Enregistrer</button>
  <button class="btn-secondary" onclick="closeSheet()">Annuler</button>
</div>
```

  </div>
</div>

<script>
const MONTHS=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
const fmt=v=>v.toLocaleString('fr-FR',{minimumFractionDigits:2,maximumFractionDigits:2})+' €';
const pct=(v,t)=>t>0?Math.min(100,Math.round(v/t*100)):0;
const ICONS={'Courses':'🛒','Essence':'⛽','Bébé':'🍼','Crèche':'🏫','Santé':'❤️','Loisirs':'🎉','Restaurant':'🍽️','Vêtements':'👗','Abonnements':'📱','Épargne':'💰','Logement':'🏠','Transport':'🚗','Autre':'📦'};

const DEF={cur:4,config:{revenus:[{id:1,name:'Salaire',amt:1711.48},{id:2,name:'CAF',amt:541.16}],epargnes:[{id:1,name:'Assurance vie',amt:53.06}],chargesFixes:[{id:1,name:'Mutuelle',amt:172.9,cat:'Santé'},{id:2,name:'Nespresso',amt:100,cat:'Abonnements'},{id:3,name:'Paypal',amt:43.97,cat:'Abonnements'},{id:4,name:'Abo Magazine',amt:4.99,cat:'Abonnements'},{id:5,name:'Téléphone Orange',amt:6.99,cat:'Abonnements'}]},months:{}};

let S,editId=null,sheetMode='dep';

function save(){try{localStorage.setItem('budgetv3',JSON.stringify(S));}catch(e){}}
function load(){try{const d=localStorage.getItem('budgetv3');S=d?JSON.parse(d):JSON.parse(JSON.stringify(DEF));}catch(e){S=JSON.parse(JSON.stringify(DEF));}}
function getM(m){if(!S.months[m])S.months[m]={vars:[],revExtra:[],dec:null};return S.months[m];}

const FORMS=['fDep','fRevEx','fDec','fAddRev','fAddEp','fAddCf','fEditRev','fEditEp','fEditCf'];

function openFor(mode){
  sheetMode=mode;
  FORMS.forEach(f=>document.getElementById(f).style.display='none');
  const tabs=document.getElementById('sheetTabs');
  if(mode==='dep'||mode==='revEx'){
    document.getElementById('sheetTitle').textContent='Ajouter';
    tabs.style.display='flex';
    document.querySelectorAll('.type-tab').forEach((t,i)=>{t.classList.toggle('active',i===0);});
    document.getElementById('fDep').style.display='';
  } else {
    tabs.style.display='none';
    const map={addRev:{title:'Nouveau revenu fixe',form:'fAddRev'},addEp:{title:'Nouvelle épargne',form:'fAddEp'},addCf:{title:'Nouvelle charge fixe',form:'fAddCf'},editRev:{title:'Modifier le revenu',form:'fEditRev'},editEp:{title:"Modifier l'épargne",form:'fEditEp'},editCf:{title:'Modifier la charge',form:'fEditCf'}};
    const cfg=map[mode];
    if(cfg){document.getElementById('sheetTitle').textContent=cfg.title;document.getElementById(cfg.form).style.display='';}
    if(mode.startsWith('add')){
      const inputs=document.getElementById(map[mode].form).querySelectorAll('input');
      inputs.forEach(i=>i.value='');
    }
  }
  document.getElementById('sheetOverlay').classList.add('open');
}

function closeSheet(){document.getElementById('sheetOverlay').classList.remove('open');}
function closeBg(e){if(e.target===document.getElementById('sheetOverlay'))closeSheet();}

function setTab(tab,el){
  document.querySelectorAll('.type-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('fDep').style.display=tab==='dep'?'':'none';
  document.getElementById('fRevEx').style.display=tab==='revEx'?'':'none';
  document.getElementById('fDec').style.display=tab==='dec'?'':'none';
}

function submitDep(){
  const desc=document.getElementById('fDepDesc').value.trim();
  const amt=parseFloat(document.getElementById('fDepAmt').value);
  const cat=document.getElementById('fDepCat').value;
  if(!desc||isNaN(amt)||amt<=0)return;
  getM(S.cur).vars.push({id:Date.now(),name:desc,amt,cat});
  document.getElementById('fDepDesc').value='';document.getElementById('fDepAmt').value='';
  save();render();closeSheet();toast('Dépense ajoutée ✓');
}

function submitRevEx(){
  const desc=document.getElementById('fRevExDesc').value.trim();
  const amt=parseFloat(document.getElementById('fRevExAmt').value);
  if(!desc||isNaN(amt)||amt<=0)return;
  getM(S.cur).revExtra.push({id:Date.now(),name:desc,amt});
  document.getElementById('fRevExDesc').value='';document.getElementById('fRevExAmt').value='';
  save();render();closeSheet();toast('Revenu ajouté ✓');
}

function submitDec(){
  const val=parseFloat(document.getElementById('fDecAmt').value);
  if(isNaN(val))return;
  getM(S.cur).dec={val,note:document.getElementById('fDecNote').value.trim(),date:new Date().toLocaleDateString('fr-FR')};
  save();render();closeSheet();toast('Découvert enregistré ✓');
}

function submitAddRev(){
  const name=document.getElementById('fAddRevName').value.trim();
  const amt=parseFloat(document.getElementById('fAddRevAmt').value);
  if(!name||isNaN(amt)||amt<=0)return;
  S.config.revenus.push({id:Date.now(),name,amt});
  save();render();closeSheet();toast('Revenu ajouté ✓');
}
function submitAddEp(){
  const name=document.getElementById('fAddEpName').value.trim();
  const amt=parseFloat(document.getElementById('fAddEpAmt').value);
  if(!name||isNaN(amt)||amt<=0)return;
  S.config.epargnes.push({id:Date.now(),name,amt});
  save();render();closeSheet();toast('Épargne ajoutée ✓');
}
function submitAddCf(){
  const name=document.getElementById('fAddCfName').value.trim();
  const amt=parseFloat(document.getElementById('fAddCfAmt').value);
  const cat=document.getElementById('fAddCfCat').value;
  if(!name||isNaN(amt)||amt<=0)return;
  S.config.chargesFixes.push({id:Date.now(),name,amt,cat});
  save();render();closeSheet();toast('Charge ajoutée ✓');
}

function editRev(id){const it=S.config.revenus.find(r=>r.id===id);if(!it)return;editId=id;document.getElementById('fEditRevName').value=it.name;document.getElementById('fEditRevAmt').value=it.amt;openFor('editRev');}
function submitEditRev(){const name=document.getElementById('fEditRevName').value.trim();const amt=parseFloat(document.getElementById('fEditRevAmt').value);if(!name||isNaN(amt)||amt<=0)return;const it=S.config.revenus.find(r=>r.id===editId);if(it){it.name=name;it.amt=amt;}save();render();closeSheet();toast('Modifié ✓');}
function delRev(id){if(!confirm('Supprimer ce revenu ?'))return;S.config.revenus=S.config.revenus.filter(r=>r.id!==id);save();render();}

function editEp(id){const it=S.config.epargnes.find(e=>e.id===id);if(!it)return;editId=id;document.getElementById('fEditEpName').value=it.name;document.getElementById('fEditEpAmt').value=it.amt;openFor('editEp');}
function submitEditEp(){const name=document.getElementById('fEditEpName').value.trim();const amt=parseFloat(document.getElementById('fEditEpAmt').value);if(!name||isNaN(amt)||amt<=0)return;const it=S.config.epargnes.find(e=>e.id===editId);if(it){it.name=name;it.amt=amt;}save();render();closeSheet();toast('Modifié ✓');}
function delEp(id){if(!confirm('Supprimer cette épargne ?'))return;S.config.epargnes=S.config.epargnes.filter(e=>e.id!==id);save();render();}

function editCf(id){const it=S.config.chargesFixes.find(c=>c.id===id);if(!it)return;editId=id;document.getElementById('fEditCfName').value=it.name;document.getElementById('fEditCfAmt').value=it.amt;openFor('editCf');}
function submitEditCf(){const name=document.getElementById('fEditCfName').value.trim();const amt=parseFloat(document.getElementById('fEditCfAmt').value);if(!name||isNaN(amt)||amt<=0)return;const it=S.config.chargesFixes.find(c=>c.id===editId);if(it){it.name=name;it.amt=amt;}save();render();closeSheet();toast('Modifié ✓');}
function delCf(id){if(!confirm('Supprimer cette charge ?'))return;S.config.chargesFixes=S.config.chargesFixes.filter(c=>c.id!==id);save();render();}

function delVarItem(id){getM(S.cur).vars=getM(S.cur).vars.filter(d=>d.id!==id);save();render();}
function delRevEx(id){getM(S.cur).revExtra=getM(S.cur).revExtra.filter(r=>r.id!==id);save();render();}

function render(){
  const m=getM(S.cur),cfg=S.config;
  const totalRev=cfg.revenus.reduce((s,r)=>s+r.amt,0);
  const totalRevEx=m.revExtra.reduce((s,r)=>s+r.amt,0);
  const totalEp=cfg.epargnes.reduce((s,e)=>s+e.amt,0);
  const totalFix=cfg.chargesFixes.reduce((s,c)=>s+c.amt,0);
  const totalVar=m.vars.reduce((s,d)=>s+d.amt,0);
  const totalIn=totalRev+totalRevEx;
  const dec=m.dec;
  // Découvert = montant négatif à déduire (ex: solde compte -200 => on déduit 200)
  const decMontant=dec?Math.abs(dec.val):0;
  const solde=totalIn-totalFix-totalEp-totalVar-decMontant;

  document.getElementById('hMonth').textContent=MONTHS[S.cur]+' 2026';
  const hs=document.getElementById('hSolde');
  hs.textContent=fmt(solde);hs.className='solde-val '+(solde>=0?'pos':'neg');

  document.getElementById('kRev').textContent=fmt(totalIn);
  document.getElementById('kRevSub').textContent=cfg.revenus.length+' source(s)'+(totalRevEx>0?' + extras':'');
  document.getElementById('kFix').textContent=fmt(totalFix);
  document.getElementById('kFixSub').textContent=cfg.chargesFixes.length+' postes';
  document.getElementById('kVar').textContent=fmt(totalVar);
  document.getElementById('kVarSub').textContent=m.vars.length+' dépense(s)';
  document.getElementById('kEp').textContent=fmt(totalEp);

  const revExHtml=m.revExtra.map(r=>`<div class="recap-item"><span class="recap-label" style="font-style:italic">${r.name}</span><span class="recap-val" style="color:var(--green)">+ ${fmt(r.amt)} <button onclick="delRevEx(${r.id})" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:13px;margin-left:4px">×</button></span></div>`).join('');
  const decHtml=dec
    ?`<div class="recap-item"><span class="recap-label" style="color:var(--red)">Découvert bancaire <button onclick="openFor('dep');setTabDirect('dec')" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:13px;margin-left:2px">✎</button></span><span class="recap-val" style="color:var(--red)">− ${fmt(decMontant)}</span></div>${dec.note?`<div style="padding:2px 16px 8px;font-size:11px;color:var(--text3);font-style:italic">${dec.note}</div>`:''}`
    :`<div class="recap-item" style="cursor:pointer" onclick="openFor('dep');setTabDirect('dec')"><span class="recap-label" style="color:var(--text3)">Découvert</span><span style="font-size:12px;color:var(--accent)">Renseigner →</span></div>`;
  document.getElementById('recapCard').innerHTML=`
    <div class="recap-item"><span class="recap-label">Revenus fixes</span><span class="recap-val" style="color:var(--green)">+ ${fmt(totalRev)}</span></div>
    ${revExHtml}
    <div class="recap-item"><span class="recap-label">Charges fixes</span><span class="recap-val" style="color:var(--red)">− ${fmt(totalFix)}</span></div>
    <div class="recap-item"><span class="recap-label">Épargne</span><span class="recap-val" style="color:var(--blue)">− ${fmt(totalEp)}</span></div>
    <div class="recap-item"><span class="recap-label">Dépenses variables</span><span class="recap-val" style="color:var(--orange)">− ${fmt(totalVar)}</span></div>
    ${decHtml}
    <div class="recap-divider"></div>
    <div class="recap-item" style="padding:14px 16px"><span class="recap-label" style="font-weight:500;color:var(--text)">Solde réel estimé</span><span class="recap-val" style="font-size:20px;color:${solde>=0?'var(--green)':'var(--red)'}">${fmt(solde)}</span></div>`;

    document.getElementById('fixList').innerHTML=cfg.chargesFixes.map(c=>`<div class="card-row"><div class="row-icon">${ICONS[c.cat]||'📦'}</div><div class="row-body"><div class="row-name">${c.name}</div><div class="row-sub">${c.cat}</div></div><div class="row-amt" style="color:var(--red)">${fmt(c.amt)}</div></div>`).join('')||'<div class="empty-state">Aucune charge fixe</div>';
  document.getElementById('fixTotal2').textContent=fmt(totalFix);

  document.getElementById('varBadge').textContent=m.vars.length;
  document.getElementById('varList').innerHTML=m.vars.length
    ?[...m.vars].reverse().map(d=>`<div class="card-row"><div class="row-icon">${ICONS[d.cat]||'📦'}</div><div class="row-body"><div class="row-name">${d.name}</div><div class="row-sub">${d.cat}</div></div><div class="row-amt" style="color:var(--orange)">${fmt(d.amt)}</div><button class="row-btn" onclick="delVarItem(${d.id})">×</button></div>`).join('')
    :'<div class="empty-state">Aucune dépense variable<br><span style="font-size:12px">Appuyez sur ⊕ pour en ajouter</span></div>';

  document.getElementById('revList').innerHTML=cfg.revenus.map(r=>`<div class="sr"><div class="sr-left"><div class="sr-name">${r.name}</div></div><div class="sr-right"><span class="sr-val" style="color:var(--green)">${fmt(r.amt)}</span><button class="btn-edit" onclick="editRev(${r.id})">Modifier</button><button class="btn-del" onclick="delRev(${r.id})">×</button></div></div>`).join('')||'<div style="padding:14px 16px;color:var(--text3);font-size:13px">Aucun revenu</div>';
  document.getElementById('epList').innerHTML=cfg.epargnes.map(e=>`<div class="sr"><div class="sr-left"><div class="sr-name">${e.name}</div></div><div class="sr-right"><span class="sr-val" style="color:var(--blue)">${fmt(e.amt)}</span><button class="btn-edit" onclick="editEp(${e.id})">Modifier</button><button class="btn-del" onclick="delEp(${e.id})">×</button></div></div>`).join('')||'<div style="padding:14px 16px;color:var(--text3);font-size:13px">Aucune épargne</div>';
  document.getElementById('cfList').innerHTML=cfg.chargesFixes.map(c=>`<div class="sr"><div class="sr-left"><div class="sr-name">${c.name}</div><div class="sr-sub">${c.cat}</div></div><div class="sr-right"><span class="sr-val" style="color:var(--red)">${fmt(c.amt)}</span><button class="btn-edit" onclick="editCf(${c.id})">Modifier</button><button class="btn-del" onclick="delCf(${c.id})">×</button></div></div>`).join('')||'<div style="padding:14px 16px;color:var(--text3);font-size:13px">Aucune charge fixe</div>';
}

function switchView(name,btn){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById('view'+name).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  if(btn)btn.classList.add('active');
  document.getElementById('content').scrollTop=0;
  document.getElementById('monthScroll').style.display=name==='Settings'?'none':'';
}

function switchMonth(m){
  S.cur=m;
  document.querySelectorAll('.mtab').forEach(t=>t.classList.toggle('active',parseInt(t.dataset.m)===m));
  render();
}

function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2500);}

function setTabDirect(tab){
  const tabs=document.querySelectorAll('.type-tab');
  tabs.forEach(t=>t.classList.remove('active'));
  const map={'dep':0,'revEx':1,'dec':2};
  if(tabs[map[tab]])tabs[map[tab]].classList.add('active');
  document.getElementById('fDep').style.display=tab==='dep'?'':'none';
  document.getElementById('fRevEx').style.display=tab==='revEx'?'':'none';
  document.getElementById('fDec').style.display=tab==='dec'?'':'none';
}
function init(){
  load();
  document.getElementById('hDate').textContent=new Date().toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'});
  const tabs=document.getElementById('monthTabs');
  [4,5,6,7,8,9,10,11].forEach(m=>{
    const b=document.createElement('button');
    b.className='mtab'+(m===S.cur?' active':'');
    b.dataset.m=m;b.textContent=MONTHS[m];
    b.onclick=()=>switchMonth(m);
    tabs.appendChild(b);
  });
  render();
}
init();
</script>

</body>
</html>
